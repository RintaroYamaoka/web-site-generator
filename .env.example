# まだ何も設定していなくても OK。サイト生成・デプロイをするときに以下を設定する。
# コピー: cp .env.example .env のあと、値を入れる。

# 必須: サイト生成時の LLM（08 選定: Gemini 3 Flash Preview）
# 取得: https://aistudio.google.com/ → Get API key
GEMINI_API_KEY=

# 必須: 生成サイトの Vercel デプロイ用
# 取得: https://vercel.com/account/tokens → Create Token
VERCEL_TOKEN=

# 任意: 生成サイトのデプロイ先。未指定は preview（本番扱いにしない）
# preview / production
# VERCEL_DEPLOY_TARGET=preview

# 任意: 1 にするとデプロイ前のローカルビルド検証をスキップ（サーバーレスでタイムアウトする場合など）
# SKIP_BUILD_VERIFY=1

# 任意: 生成サイト用の GitHub リポジトリを作る場合（05）。作成する場合は private で作成する。
# GITHUB_TOKEN=
